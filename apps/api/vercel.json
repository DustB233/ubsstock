{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/app.py"
    }
  ],
  "functions": {
    "app.py": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/v1/cron/hobby-data-refresh",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/v1/cron/hobby-analysis",
      "schedule": "30 11 * * *"
    }
  ]
}
