{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/cron/daily-refresh",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/v1/cron/fundamentals-analyze-score",
      "schedule": "30 11 * * *"
    }
  ]
}
